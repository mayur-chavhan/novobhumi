# ===========================================
# Novobhumi - Environment Configuration
# ===========================================
# Copy this file to .env and update values

# ----- Frontend Configuration -----
FRONTEND_PORT=80
VITE_API_URL=http://localhost:3001

# ----- Backend Configuration -----
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost

# ----- Database Configuration -----
DATABASE_URL=mysql://novobhumi:your_secure_password@database:3306/novobhumi
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=novobhumi
MYSQL_USER=novobhumi
MYSQL_PASSWORD=your_secure_password

# ----- Authentication -----
SESSION_SECRET=generate_a_secure_random_string_here
ADMIN_EMAIL=admin@novobhumi.com
ADMIN_PASSWORD=change_this_password

# ----- SMTP Configuration (Optional) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ----- Docker Hub (for CI/CD) -----
# These are used in GitHub Actions secrets, not in .env
# DOCKERHUB_USERNAME=your_dockerhub_username
# DOCKERHUB_TOKEN=your_dockerhub_access_token
