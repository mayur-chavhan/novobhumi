# ===========================================
# Novobhumi - Analytics & Tracking Configuration
# ===========================================
# Copy this file to .env and update values
# 
# IMPORTANT: These IDs must be manually replaced in index.html
# Search and replace the following placeholder strings:
# - GA4_MEASUREMENT_ID
# - GTM_CONTAINER_ID
# - GOOGLE_SITE_VERIFICATION
# - ADSENSE_PUBLISHER_ID
# - CLARITY_PROJECT_ID
# - HOTJAR_ID (must be numeric)
# - FB_PIXEL_ID
#
# The scripts will only load if valid IDs are provided (not placeholders)

# Google Analytics 4
# Get from: https://analytics.google.com/ > Admin > Data Streams
# Format: G-XXXXXXXXXX
VITE_GA4_MEASUREMENT_ID=GA4_MEASUREMENT_ID

# Google Tag Manager
# Get from: https://tagmanager.google.com/ > Container ID
# Format: GTM-XXXXXXX
VITE_GTM_CONTAINER_ID=GTM_CONTAINER_ID

# Google Search Console
# Get from: https://search.google.com/search-console > Settings > Ownership verification
VITE_GOOGLE_SITE_VERIFICATION=GOOGLE_SITE_VERIFICATION

# Google AdSense Publisher ID
# Get from: https://www.google.com/adsense/ > Account > Publisher ID
# Format: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_PUBLISHER_ID=ADSENSE_PUBLISHER_ID

# Microsoft Clarity
# Get from: https://clarity.microsoft.com/ > Project Settings
VITE_CLARITY_PROJECT_ID=CLARITY_PROJECT_ID

# Hotjar
# Get from: https://www.hotjar.com/ > Sites > Site ID
# Format: Numeric ID (e.g., 1234567)
VITE_HOTJAR_ID=HOTJAR_ID

# Facebook Pixel
# Get from: https://business.facebook.com/events_manager > Pixel ID
# Format: Numeric string (e.g., 123456789012345)
VITE_FB_PIXEL_ID=FB_PIXEL_ID
